# GCP project
GOOGLE_CLOUD_PROJECT=jutra-493710
GOOGLE_APPLICATION_CREDENTIALS=./jutra-493710-f25c69585e55.json

# Vertex AI (ADK uses google-genai under the hood)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_LOCATION=global
LLM_LOCATION=global
EMBED_LOCATION=europe-west4

# Models (Gemini 3 preview; fallback handles deprecation mid-hackathon)
MODEL_REASONING=gemini-3.1-pro-preview
MODEL_CHAT=gemini-3-flash-preview
MODEL_EXTRACT=gemini-3.1-flash-lite-preview
EMBED_MODEL=text-embedding-005
FALLBACK_MODEL=gemini-2.5-flash

# MCP auth (production value pulled from Secret Manager mcp-bearer)
MCP_BEARER_TOKEN=dev-local-token
API_BEARER_TOKEN=dev-local-token

# Runtime
LOG_LEVEL=INFO
PORT=8080

# HS256 secret for /auth/register and /auth/login (min ~32 chars). Empty = auth endpoints return 503.
AUTH_JWT_SECRET=
